    {
      "type": "part",
      "id": "b2-part-3",
      "label": "ТЕТРАДЬ III",
      "title": "Время не лечит",
      "items": [
        { "type": "poem", "id": "b2-poem-24", "title": "А после — перекошенная дверь…", "page": 24 },
        { "type": "poem", "id": "b2-poem-25", "title": "Голос Времени", "page": 25 },
        { "type": "poem", "id": "b2-poem-26", "title": "А вот себя я победить не смог…", "page": 26 },
        { "type": "poem", "id": "b2-poem-27", "title": "Из черновиков (Любовь должна быть…)", "page": 27 },
        { "type": "poem", "id": "b2-poem-28", "title": "Мы снова встретимся…", "page": 28 },
        { "type": "poem", "id": "b2-poem-29", "title": "Ты знаешь, я скучаю по тебе…", "page": 29 },
        { "type": "poem", "id": "b2-poem-30", "title": "Бесценно время", "page": 30 },
        { "type": "poem", "id": "b2-poem-31", "title": "Время не лечит", "page": 31 },
        { "type": "poem", "id": "b2-poem-32", "title": "Октябрь зачастил…", "page": 32 },
        { "type": "poem", "id": "b2-poem-33", "title": "Я точно знал: меня весна обманет…", "page": 33 },
        { "type": "poem", "id": "b2-poem-34", "title": "Серое небо придавит дождём…", "page": 34 },
        { "type": "poem", "id": "b2-poem-35", "title": "Ты ищешь край неба…", "page": 35 },
        { "type": "poem", "id": "b2-poem-36", "title": "Нельзя откладывать счастье…", "page": 36 },
        { "type": "poem", "id": "b2-poem-37", "title": "Нет жизни вне любви…", "page": 37 },
        { "type": "poem", "id": "b2-poem-38", "title": "Как-то странно звучит из-под снега…", "page": 38 }
      ]
    },
    {
      "type": "part",
      "id": "b2-part-4",
      "label": "ТЕТРАДЬ IV",
      "title": "Как много прожитого наспех",
      "items": [
        { "type": "poem", "id": "b2-poem-39", "title": "Мы можем по душе и сердцу жить", "page": 39 },
        { "type": "poem", "id": "b2-poem-40", "title": "То, что прожили, можно сложить…", "page": 40 },
        { "type": "poem", "id": "b2-poem-41", "title": "Январь на качелях", "page": 41 },
        { "type": "poem", "id": "b2-poem-42", "title": "Когда тебя уже совсем не слышат…", "page": 42 },
        { "type": "poem", "id": "b2-poem-43", "title": "Молчание порой как крик в ответ…", "page": 43 },
        { "type": "poem", "id": "b2-poem-44", "title": "Как много прожитого наспех…", "page": 44 },
        { "type": "poem", "id": "b2-poem-45", "title": "Моя беда в том, что я всё понимаю…", "page": 45 },
        { "type": "poem", "id": "b2-poem-46", "title": "Искусство отсеивания", "page": 46 },
        { "type": "poem", "id": "b2-poem-47", "title": "Не ври, что забыла…", "page": 47 },
        { "type": "poem", "id": "b2-poem-48", "title": "Осенний манифест", "page": 48 },
        { "type": "poem", "id": "b2-poem-49", "title": "Похолодало…", "page": 49 },
        { "type": "poem", "id": "b2-poem-50", "title": "Ворон (Черная капля)", "page": 50 },
        { "type": "poem", "id": "b2-poem-51", "title": "Давай с тобой поговорим…", "page": 51 },
        { "type": "poem", "id": "b2-poem-52", "title": "Слова, что ты бросала мне…", "page": 52 },
        { "type": "poem", "id": "b2-poem-53", "title": "Вокзал, с которого не уехать", "page": 53 }
      ]
    },
